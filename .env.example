# Hugging Face API Token
# Get your token from: https://huggingface.co/settings/tokens
# Create a token with "Read" permissions (free)
HF_TOKEN=your_token_here

# Model configuration
HF_MODEL=google/gemma-2-2b-it

# API configuration
API_PORT=8000
API_HOST=0.0.0.0

# Firebase / Firestore configuration
# Set FIREBASE_ENABLED=true to enable saving AI responses to Firestore.
FIREBASE_ENABLED=false
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_PATH=path/to/serviceAccountKey.json
# Or store the service account JSON string directly (one line or escaped JSON).
# FIREBASE_CREDENTIALS_JSON={"type":"service_account", ...}
FIREBASE_COLLECTION=ai_responses
